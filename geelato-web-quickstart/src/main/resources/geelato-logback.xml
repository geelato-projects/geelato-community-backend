<?xml version="1.0" encoding="UTF-8"?>
<configuration scan="true" scanPeriod="60 seconds" debug="false">
    <contextName>geelato-logback</contextName>
    <property name="LOG_DIR" value="${LOG_DIR:-~/log}"/>
    <property name="ROOT_LOG_LEVEL" value="${ROOT_LOG_LEVEL:-DEBUG}"/>
    <property name="FILE_LOG_LEVEL" value="${FILE_LOG_LEVEL:-DEBUG}"/>
    <property name="CONSOLE_LOG_LEVEL" value="${CONSOLE_LOG_LEVEL:-${ROOT_LOG_LEVEL}}"/>
    <property name="RESOLVE_LOG_LEVEL" value="${RESOLVE_LOG_LEVEL:-DEBUG}"/>
    <property name="LOG_PATTERN" value="${LOG_PATTERN:-%d{HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n}"/>
    <!--输出到控制台-->
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${CONSOLE_LOG_LEVEL}</level>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>
    <appender name="errorLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/error/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${ERROR_FILE_LOG_LEVEL:-ERROR}</level>
        </filter>
    </appender>
    <appender name="infoLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/info/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${FILE_LOG_LEVEL}</level>
        </filter>
    </appender>
    <appender name="platformExceptionLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/error/platform-runtime-exception.%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${PLATFORM_EXCEPTION_FILE_LEVEL:-ERROR}</level>
        </filter>
    </appender>
<!--    <appender name="custom" class="cn.geelato.logging.logback.SystemLoggingAppender">-->
<!--    </appender>-->
    <!--默认日志-->
    <appender name="logFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/%d{yyyy-MM-dd}/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
    </appender>
    <!--调度服务日志-->
    <appender name="scheduleLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/schedule/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
    </appender>
    <!--认证服务日志-->
    <appender name="authLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/auth/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
    </appender>
    <!--消息服务日志-->
    <appender name="messageLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/message/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
    </appender>
    <!--拦截器日志-->
    <appender name="interceptorLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/interceptor/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
    </appender>
    <!--请求记录日志-->
    <appender name="requestLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/request/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>2</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>%d{HH:mm:ss} - %msg%n</pattern>
        </layout>
    </appender>
    <!--解析接口日志-->
    <appender name="resolveLogFile" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <Prudent>true</Prudent>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <FileNamePattern>${LOG_DIR}/resolve/%d{yyyy-MM-dd}.%i.log</FileNamePattern>
            <maxFileSize>1000MB</maxFileSize>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <layout class="ch.qos.logback.classic.PatternLayout">
            <pattern>${LOG_PATTERN}</pattern>
        </layout>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${RESOLVE_LOG_LEVEL}</level>
        </filter>
    </appender>
    <logger name="cn.geelato.schedule" additivity="false">
        <appender-ref ref="scheduleLogFile"/>
        <appender-ref ref="console"/>
    </logger>
    <logger name="cn.geelato.auth" additivity="false">
        <appender-ref ref="authLogFile"/>
        <appender-ref ref="console"/>
    </logger>
    <logger name="cn.geelato.message" additivity="false">
        <appender-ref ref="messageLogFile"/>
        <appender-ref ref="console"/>
    </logger>
    <logger name="cn.geelato.web.common.interceptor" additivity="false">
        <appender-ref ref="interceptorLogFile"/>
        <appender-ref ref="console"/>
    </logger>
    <logger name="cn.geelato.web.platform.boot.interceptor" additivity="false">
        <appender-ref ref="requestLogFile"/>
        <appender-ref ref="console"/>
    </logger>
    <logger name="cn.geelato.web.platform.resolve" level="${RESOLVE_LOG_LEVEL}" additivity="false">
        <appender-ref ref="resolveLogFile"/>
    </logger>
    <logger name="cn.geelato.web.platform.srv.resolve" level="${RESOLVE_LOG_LEVEL}" additivity="false">
        <appender-ref ref="resolveLogFile"/>
    </logger>
    <logger name="cn.geelato.web.platform.run.PlatformExceptionHandler" level="${PLATFORM_EXCEPTION_LOG_LEVEL:-ERROR}" additivity="false">
        <appender-ref ref="platformExceptionLogFile"/>
        <appender-ref ref="console"/>
    </logger>
<!--    <logger name="handler.cn.geelato.web.platform.PlatformExceptionHandler" additivity="false">-->
<!--        <appender-ref ref="custom"/>-->
<!--    </logger>-->
    <root level="${ROOT_LOG_LEVEL}">
        <appender-ref ref="console"/>
        <appender-ref ref="infoLogFile"/>
        <appender-ref ref="errorLogFile"/>
    </root>

</configuration>
